# データベース接続設定
# ※ 実際の接続情報を記入して settings.yaml として保存してください
database:
  eco:
    user: "YOUR_ECO_USER"
    password: "YOUR_ECO_PASSWORD"
    dsn: "hostname:1521/service_name"
    pool_min: 2
    pool_max: 10
  honps:
    user: "YOUR_HONPS_USER"
    password: "YOUR_HONPS_PASSWORD"
    dsn: "hostname:1521/service_name"
    pool_min: 1
    pool_max: 5

# バッチ処理設定
batch:
  chunk_size: 999  # OracleのIN句上限
  max_depth: 10    # A番の再帰解決上限

# 製造原価計算
manufacturing:
  up_rate_cell: "Q1"       # テーブルシートのA3相当
  charge_rate_cell: "R1"   # テーブルシートのB3相当
  history_days: 365        # 標準加工数の平均計算期間
